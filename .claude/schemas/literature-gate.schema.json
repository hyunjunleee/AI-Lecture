{
  "title": "literature-gate-source-fidelity JSONL record",
  "type": "object",
  "required": [
    "schema_version",
    "lecture",
    "iter",
    "mode",
    "inputs",
    "verdict",
    "stall_count",
    "sections",
    "global_checks",
    "revision_directives",
    "evidence"
  ],
  "properties": {
    "schema_version": {
      "const": "literature-gate-source-fidelity"
    },
    "lecture": {
      "type": "string",
      "pattern": "^[0-9]{2}$"
    },
    "iter": {
      "type": "integer",
      "minimum": 1
    },
    "mode": {
      "enum": [
        "dossier",
        "lecture"
      ]
    },
    "inputs": {
      "type": "object"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "stall_count": {
      "type": "integer",
      "minimum": 0
    },
    "sections": {
      "type": "array"
    },
    "revision_directives": {
      "type": "array"
    },
    "evidence": {
      "type": "object"
    },
    "global_checks": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
