{
  "title": "math-gate-source-fidelity JSONL record",
  "type": "object",
  "required": ["schema_version", "lecture", "iter", "inputs", "verdict", "stall_count", "sections", "global_checks", "revision_directives", "evidence"],
  "properties": {
    "schema_version": {"const": "math-gate-source-fidelity"},
    "lecture": {"type": "string", "pattern": "^[0-9]{2}$"},
    "iter": {"type": "integer", "minimum": 1},
    "inputs": {"type": "object", "required": ["lecture_tex", "theory_md", "typeset_report"]},
    "verdict": {"enum": ["PASS", "FAIL"]},
    "stall_count": {"type": "integer", "minimum": 0},
    "sections": {"type": "array"},
    "global_checks": {"type": "object"},
    "revision_directives": {"type": "array"},
    "evidence": {"type": "object"}
  },
  "additionalProperties": true
}
